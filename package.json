{
	"name": "stratacss-postcss",
	"version": "0.1.0",
	"private": true,
	"description": "StrataCSS official sample (PostCSS / postcss-import)",
	"license": "MIT",
	"scripts": {
		"dev": "npm run build:static && run-p dev:css dev:serve dev:static",
		"build": "npm run clean && npm run build:static && npm run build:css",
		"dev:css": "postcss src/styles/global.css \"src/styles/pages/*.css\" --base src/styles --dir dist/assets/css --no-map --watch",
		"dev:serve": "browser-sync start --server dist --startPath / --files \"dist/**/*\" --no-notify",
		"dev:static": "node scripts/copy-static.mjs --watch",
		"build:css": "postcss src/styles/global.css \"src/styles/pages/*.css\" --base src/styles --dir dist/assets/css --no-map",
		"build:static": "node scripts/copy-static.mjs",
		"clean": "rm -rf dist"
	},
	"devDependencies": {
		"browser-sync": "^3.0.4",
		"chokidar": "^5.0.0",
		"npm-run-all2": "^8.0.4",
		"postcss": "^8.5.0",
		"postcss-cli": "^11.0.0",
		"postcss-import": "^16.1.0"
	},
	"dependencies": {
		"animate.css": "^4.1.1",
		"kiso.css": "^1.2.4"
	}
}
